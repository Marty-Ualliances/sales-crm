# Core runtime
NODE_ENV=development
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority
JWT_SECRET=replace_with_at_least_32_chars_secret
JWT_REFRESH_SECRET=replace_with_another_long_secret
ALLOWED_ORIGINS=http://localhost:3000

# Optional email
RESEND_API_KEY=
SMTP_FROM=noreply@ualliances.com

# Seed credentials (required for npm run seed)
SEED_ADMIN_PASSWORD=change_this_admin_password
SEED_TEAM_PASSWORD=change_this_team_password
